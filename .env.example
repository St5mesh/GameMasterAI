# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gamemaster?retryWrites=true&w=majority

# Session Security
SESSION_SECRET=your_random_session_secret_here
JWT_SECRET=your_random_jwt_secret_here

# AI Provider Configuration
# Options: 'openai' or 'lmstudio'
AI_PROVIDER=lmstudio

# OpenAI Configuration (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your_openai_api_key_here

# LM Studio Configuration (only needed if AI_PROVIDER=lmstudio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL_DM=local-model-name
LM_STUDIO_MODEL_CAMPAIGN=local-model-name
LM_STUDIO_MODEL_SUMMARY=local-model-name

# Server Configuration
PORT=5001
# HOST - Set to 0.0.0.0 to allow access from LAN devices (required for mobile access)
# Set to localhost or 127.0.0.1 to restrict to local machine only
HOST=0.0.0.0

# CORS Configuration
# CORS_ORIGIN - Set to * to allow all origins (useful for LAN/mobile access)
# Or specify allowed origins separated by commas: http://192.168.1.100:8080,http://localhost:8080
# Default is * (allow all) if not specified
CORS_ORIGIN=*
