# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string

# API Configuration
# For OpenAI (default):
# Leave LM_STUDIO_BASE_URL commented out and set your OpenAI API key
OPENAI_API_KEY=your_openai_api_key

# For LM Studio (local AI):
# Uncomment the line below and set it to your LM Studio server URL
# The API key can be left empty or removed when using LM Studio locally
# LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Security
SESSION_SECRET=your_session_secret
JWT_SECRET=your_jwt_secret

# Server Configuration
PORT=5001
